# ============================================
# PrintForge Environment Variables
# ============================================
# Copy this file to .env.local and fill in the values

# --- Vercel Postgres ---
# Auto-injected when you link a Vercel Postgres store
# For local dev: copy from Vercel Dashboard → Storage → your DB → .env.local tab
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# --- Vercel Blob ---
# Auto-injected when you link a Vercel Blob store
BLOB_READ_WRITE_TOKEN=

# --- NextAuth ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# --- Google OAuth ---
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Tripo3D API ---
# Get your key at: https://platform.tripo3d.ai/
TRIPO_API_KEY=

# --- (Optional) Order Notifications ---
# Webhook URL for Slack / Discord / LINE notifications
ORDER_WEBHOOK_URL=
